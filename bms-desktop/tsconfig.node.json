{
  "extends": "./tsconfig.json",
  "include": [
    "electron.vite.config.ts",
    "src/shared/**/*",
    "src/main/**/*",
    "src/preload/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": [
      "node",
      "electron"
    ],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  }
}
