{
  "name": "bms-workbench",
  "version": "0.1.0",
  "description": "BMS Workbench desktop app",
  "main": "out/main/index.js",
  "type": "module",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --build --force",
    "build": "npm run typecheck && electron-vite build && electron-builder"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/pretendard": "^5.2.5",
    "@vitejs/plugin-react": "^5.0.0",
    "dayjs": "^1.11.13",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2",
    "lodash": "^4.17.21",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "serialport": "^13.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.bms.workbench",
    "productName": "BMS Workbench",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
